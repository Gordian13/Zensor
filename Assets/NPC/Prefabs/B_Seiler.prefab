  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCAmbientSpeech
  npc: {fileID: 8816145889897903339}
  playerAnchor: {fileID: 0}
  triggerDistance: 4
  cooldownSeconds: 12
  chancePerCheck: 35
  checkInterval: 1
  ambientLines:
  - "Leg die Platte ruhig auf. Wenn sie dich nicht sofort versteht, gib ihr \u2019ne
    Minute."
  - "H\xF6rste dit? Da passiert was zwischen den Kratzern."
  - Fass die Platte ruhig an. Vinyl will respektiert werden, aber nich angebetet.
  - "Manchmal kam jemand rein und fragte: \u201EHaben Sie was Normales?\u201C Hab
    ick gesagt: \u201EHeute leider geschlossen.\u201C"
